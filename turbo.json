{
  "$schema": "https://turbo.build/schema.json",
  "ui": "tui",
  "tasks": {
    "lint": {
      "cache": false,
      "outputs": [],
      "inputs": ["apps/*.{ts,tsx,js,jsx}", ".eslintrc*", ".prettierrc*"],
      "dependsOn": ["^lint"]
    },
    "format": {
      "cache": false,
      "outputs": [],
      "inputs": ["apps/*.{ts,tsx,js,jsx}", ".prettierrc*"]
    },
    "build": {
      "dependsOn": ["^build"],
      "inputs": ["$TURBO_DEFAULT$", ".env*"],
      "outputs": ["dist/**", ".next/**"]
    },
    "dev": {
      "cache": false,
      "persistent": true,
      "dependsOn": ["^build"]
    },
    "check-types": {
      "dependsOn": ["^check-types"]
    },
    "translate": {
      "cache": false
    }
  }
}
